import random
from collections import defaultdict
from typing import List, Dict, Optional
from dataclasses import dataclass
from concurrent.futures import ThreadPoolExecutor, as_completed

@dataclass
class GroupingResult:
    groups: List[List[str]]
    attempts: int
    status: str
    warnings: List[str]
    used_seed: int
    balance_metrics: dict

def verify_groups(groups: List[List[str]], limits: Dict[str, List[str]], roles: Dict[str, str], 
                  genders: Dict[str, str], strict_roles: bool = True, strict_genders: bool = True) -> bool:
    flat = [p for g in groups for p in g]
    if len(flat) != len(set(flat)): return False
    if max(len(g) for g in groups) - min(len(g) for g in groups) > 1: return False

    conflicts = defaultdict(set)
    for a, bs in limits.items():
        for b in bs: conflicts[a].add(b)

    for g in groups:
        gs = set(g)
        for p in g:
            if conflicts[p] & gs: return False

    n = len(groups)
    if strict_roles:
        role_tot = defaultdict(int)
        for r in roles.values(): role_tot[r] += 1
        targets = {r: [b+(1 if i<e else 0) for i in range(n)] for r, cnt in role_tot.items() for b,e in [divmod(cnt, n)]}
        for i, g in enumerate(groups):
            gc = defaultdict(int)
            for p in g: gc[roles[p]] += 1
            for r in targets:
                if gc.get(r, 0) != targets[r][i]: return False

    if strict_genders:
        gen_tot = defaultdict(int)
        for g in genders.values(): gen_tot[g] += 1
        targets = {g: [b+(1 if i<e else 0) for i in range(n)] for g, cnt in gen_tot.items() for b,e in [divmod(cnt, n)]}
        for i, g in enumerate(groups):
            gc = defaultdict(int)
            for p in g: gc[genders[p]] += 1
            for g_type in targets:
                if gc.get(g_type, 0) != targets[g_type][i]: return False
    return True

def _run_attempt(seed: int, cfg: dict) -> Optional[GroupingResult]:
    rng = random.Random(seed)
    all_p, roles, genders, conflicts = cfg['all'], cfg['roles'], cfg['genders'], cfg['conflicts']
    size_tgt, role_tgt, gender_tgt = cfg['size_tgt'], cfg['role_tgt'], cfg['gender_tgt']
    strict_role, strict_gen, g_num = cfg['strict_role'], cfg['strict_gen'], cfg['g_num']
    
    pool = sorted(all_p, key=lambda p: len(conflicts[p]), reverse=True)
    rng.shuffle(pool)
    
    groups = [[] for _ in range(g_num)]
    g_rc = [defaultdict(int) for _ in range(g_num)]
    g_gc = [defaultdict(int) for _ in range(g_num)]
    warnings = []

    for p in pool:
        role, gen = roles[p], genders[p]
        valid = [i for i in range(g_num) 
                 if len(groups[i]) < size_tgt[i] 
                 and (not strict_role or g_rc[i][role] < role_tgt[role][i])
                 and (not strict_gen or g_gc[i][gen] < gender_tgt[gen][i])
                 and not any(p in conflicts[m] for m in groups[i])]
        if not valid:
            if strict_role or strict_gen:
                valid = [i for i in range(g_num) if len(groups[i]) < size_tgt[i] and not any(p in conflicts[m] for m in groups[i])]
                if valid and not warnings: warnings.append("Баланс ролей/полов ослаблен.")
        if not valid: return None
        
        idx = rng.choice(valid)
        groups[idx].append(p)
        g_rc[idx][role] += 1
        g_gc[idx][gen] += 1

    def calc_score():
        dev_r = sum(sum(abs(g_rc[i][r] - role_tgt[r][i]) for r in role_tgt) for i in range(g_num))
        dev_g = sum(sum(abs(g_gc[i][g] - gender_tgt[g][i]) for g in gender_tgt) for i in range(g_num))
        return dev_r + dev_g

    best_score, stagnation = calc_score(), 0
    for _ in range(150):
        if stagnation >= 25: break
        g1, g2 = rng.sample(range(g_num), 2)
        if not groups[g1] or not groups[g2]: continue
        p1, p2 = rng.choice(groups[g1]), rng.choice(groups[g2])
        r1, r2 = roles[p1], roles[p2]
        gen1, gen2 = genders[p1], genders[p2]

        if any(p1 in conflicts[m] for m in groups[g2] if m!=p2): continue
        if any(p2 in conflicts[m] for m in groups[g1] if m!=p1): continue
        if strict_role and (g_rc[g2][r1]+1 > role_tgt[r1][g2] or g_rc[g1][r2]+1 > role_tgt[r2][g1]): continue
        if strict_gen and (g_gc[g2][gen1]+1 > gender_tgt[gen1][g2] or g_gc[g1][gen2]+1 > gender_tgt[gen2][g1]): continue

        # Swap
        groups[g1].remove(p1); groups[g1].append(p2)
        groups[g2].remove(p2); groups[g2].append(p1)
        g_rc[g1][r1]-=1; g_rc[g1][r2]+=1
        g_rc[g2][r2]-=1; g_rc[g2][r1]+=1
        g_gc[g1][gen1]-=1; g_gc[g1][gen2]+=1
        g_gc[g2][gen2]-=1; g_gc[g2][gen1]+=1

        new_sc = calc_score()
        if new_sc < best_score: best_score, stagnation = new_sc, 0
        elif new_sc == best_score:
            if rng.random() < 0.1: rng.shuffle(groups)
            else: stagnation += 1
        else: # Rollback
            groups[g1].remove(p2); groups[g1].append(p1)
            groups[g2].remove(p1); groups[g2].append(p2)
            g_rc[g1][r1]+=1; g_rc[g1][r2]-=1; g_rc[g2][r2]+=1; g_rc[g2][r1]-=1
            g_gc[g1][gen1]+=1; g_gc[g1][gen2]-=1; g_gc[g2][gen2]+=1; g_gc[g2][gen1]-=1
            stagnation += 1

    n = len(groups)
    balance = {
        "size_diff": max(len(g) for g in groups) - min(len(g) for g in groups),
        "role_dev": {r: [g_rc[i][r] - role_tgt[r][i] for i in range(n)] for r in role_tgt},
        "gender_dev": {g: [g_gc[i][g] - gender_tgt[g][i] for i in range(n)] for g in gender_tgt}
    }
    return GroupingResult(groups=groups, attempts=1, status="success", warnings=warnings, used_seed=seed, balance_metrics=balance)

def generate_groups(
    group_number: int, all_people: List[str], genders: Dict[str, str],
    newbies: Optional[List[str]] = None, experts: Optional[List[str]] = None,
    roles: Optional[Dict[str, str]] = None, limits: Optional[Dict[str, List[str]]] = None,
    seed: Optional[int] = None, strict_roles: bool = True, strict_genders: bool = True,
    max_attempts: int = 500, parallel_workers: int = 0
) -> GroupingResult:
    used_seed = seed if seed is not None else random.randint(0, 2**32-1)
    all_set = set(all_people)
    if len(all_set) != len(all_people): raise ValueError("Дубликаты в all_people.")
    if len(all_people) < group_number: raise ValueError("Людей меньше, чем групп.")
    if set(genders.keys()) != all_set: raise ValueError("Список genders не совпадает с all_people.")

    if roles is None:
        if newbies and experts and set(newbies) & set(experts): raise ValueError("newbies и experts пересекаются.")
        roles = {p: 'newbie' for p in (newbies or [])}
        roles.update({p: 'expert' for p in (experts or [])})
        for p in all_people: roles.setdefault(p, 'regular')
    if set(roles) - all_set: raise ValueError("Неизвестные имена в roles.")

    limits = limits or {}
    conflicts = defaultdict(set)
    for a, bs in limits.items():
        if a not in all_set or not all(b in all_set for b in bs): raise ValueError("Невалидные имена в limits.")
        for b in bs:
            if a != b: conflicts[a].add(b); conflicts[b].add(a)

    base, ext = divmod(len(all_people), group_number)
    size_tgt = [base+(1 if i<ext else 0) for i in range(group_number)]
    max_sz = base + (1 if ext>0 else 0)
    for p, cl in conflicts.items():
        if len(cl) >= max_sz: raise RuntimeError(f"Конфликт '{p}' ({len(cl)}) > макс. размера группы ({max_sz}).")

    role_tot = defaultdict(int)
    for r in roles.values(): role_tot[r] += 1
    role_tgt = {r: [b+(1 if i<e else 0) for i in range(group_number)] for r, cnt in role_tot.items() for b,e in [divmod(cnt, group_number)]}

    gen_tot = defaultdict(int)
    for g in genders.values(): gen_tot[g] += 1
    gender_tgt = {g: [b+(1 if i<e else 0) for i in range(group_number)] for g, cnt in gen_tot.items() for b,e in [divmod(cnt, group_number)]}

    cfg = {
        'all': all_people, 'roles': roles, 'genders': genders, 'conflicts': conflicts,
        'size_tgt': size_tgt, 'role_tgt': role_tgt, 'gender_tgt': gender_tgt,
        'strict_role': strict_roles, 'strict_gen': strict_genders, 'g_num': group_number
    }
    seeds = [used_seed + i for i in range(max_attempts)]

    if parallel_workers > 1:
        with ThreadPoolExecutor(max_workers=parallel_workers) as ex:
            futs = {ex.submit(_run_attempt, s, cfg): i for i, s in enumerate(seeds)}
            for fut in as_completed(futs):
                res = fut.result()
                if res: res.attempts = futs[fut]+1; return res
    else:
        for i, s in enumerate(seeds):
            res = _run_attempt(s, cfg)
            if res: res.attempts = i+1; return res

    raise RuntimeError(f"Сборка не удалась за {max_attempts} попыток. Seed: {used_seed}")

# ========================
# Пример вызова и вывода
# ========================
if __name__ == "__main__":
    people = ["Jones","Dick","Jim","Jack","Tom","Sam","Donald","Samanta"]
    genders = {
        "Jones":"M", "Dick":"M", "Jim":"M", "Jack":"M",
        "Tom":"M", "Sam":"F", "Donald":"M", "Samanta":"F"
    }
    
    result = generate_groups(
        group_number=2,
        all_people=people,
        genders=genders,
        newbies=["Dick", "Samanta"],
        experts=["Tom","Sam"],
        limits={"Donald":["Dick"]}
    )

    print(f"✅ Статус: {result.status} | Seed: {result.used_seed} | Попыток: {result.attempts}")
    print(f"⚖️ Метрики: {result.balance_metrics}\n")
    
    for idx, group in enumerate(result.groups, start=1):
        print(f"Группа {idx}: {', '.join(group)}")
        
    # Быстрая проверка
    assert verify_groups(result.groups, {"Donald":["Dick"]}, {p:"regular" for p in people}, genders)